# brandgeo/ — ignore everything except the public website files
brandgeo/*
!brandgeo/web/
# ...but never the deploy webhook secret or its log. These live only on the
# server (uploaded by hand), must stay out of git, and must never be copied
# into the public docroot by the webhook deploy.
brandgeo/web/deploy-secret.php
brandgeo/web/deploy.log


# Secrets — never commit these
.env
credentials.json
token.json


# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class


# C extensions
*.so


# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
!brandgeo-dashboard/src/lib/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Ayrshare SSO integration package: contains the RSA private key and the
# account API key. Never commit it.
integration-guides_*.zip
*-private-key.key
*.pem
integration-guides_*/

# Quarantined stray copies from the 2026-07-24 repo reorg — redundant dups of
# now-tracked files, the 3 differing spec variants, and local-only secrets.
# Review and delete when confirmed unneeded. Never commit (contains secrets).
/_reorg-stray/
